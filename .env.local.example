# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# https://supabase.com → Your Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── ANTHROPIC (AI Report generation) ────────────────────────────────────────
# https://console.anthropic.com

ANTHROPIC_API_KEY=your-anthropic-key-here

# ─── GOOGLE CALENDAR ──────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Calendar API
# Create OAuth 2.0 Client ID (Web application)
# Authorised redirect URI: http://localhost:3000/api/calendar/callback

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# ─── PLAID (Bank sync) ────────────────────────────────────────────────────────
# https://dashboard.plaid.com → Team Settings → Keys
# PLAID_ENV: sandbox | development | production
# For testing: use "sandbox" (free, no real bank needed)

PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
